{
  "manifest_version": 2,
  "name": "zenctl bridge (privileged)",
  "version": "0.1.0",
  "description": "Bridge between the Zen browser and the zenctl CLI daemon — with experiment_apis for full feature set.",
  "browser_specific_settings": {
    "gecko": {
      "id": "zenctl@phusit.local",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "nativeMessaging",
    "storage",
    "bookmarks",
    "tabs",
    "history",
    "downloads",
    "cookies",
    "sessions",
    "browsingData",
    "contextualIdentities",
    "find",
    "search",
    "webNavigation",
    "<all_urls>"
  ],
  "experiment_apis": {
    "zenPrefs": {
      "schema": "api/zenPrefs.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "api/zenPrefs.js",
        "paths": [["zenPrefs"]]
      }
    },
    "zenChrome": {
      "schema": "api/zenChrome.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "api/zenChrome.js",
        "paths": [["zenChrome"]]
      }
    }
  },
  "background": {
    "scripts": ["src/background.js"],
    "persistent": true
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  }
}
